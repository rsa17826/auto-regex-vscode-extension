{
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:html",
    "onLanguage:ahk",
    "onLanguage:python",
    "onLanguage:gdscript",
    "onLanguage:regex"
  ],
  "version": "57.0.0",
  "categories": [
    "Other"
  ],
  "contributes": {
    "configurationDefaults": {
      "[regex]": {
        "editor.tokenColorCustomizations": {
          "textMateRules": [
            {
              "scope": "regex.replacetext",
              "settings": {
                "foreground": "#3e5a56",
                "fontStyle": "bold"
              }
            },
            {
              "scope": "regex.tag.optional",
              "settings": {
                "foreground": "#009faade"
              }
            },
            {
              "scope": "regex.tag.noregex",
              "settings": {
                "foreground": "#b46000f8",
                "fontStyle": "bold strikethrough"
              }
            },
            {
              "scope": "regex.tag.name",
              "settings": {
                "foreground": "#2ab400f8"
              }
            },
            {
              "scope": "regex.tag.forced",
              "settings": {
                "foreground": "#00b496f8"
              }
            },
            {
              "scope": "regex.anytext",
              "settings": {
                "foreground": "#afa9897e",
                "fontStyle": "bold"
              }
            },
            {
              "scope": "regex.any",
              "settings": {
                "foreground": "#be8211b9",
                "fontStyle": "bold"
              }
            },
            {
              "scope": "regex.repeater",
              "settings": {
                "foreground": "#00a8dbb9",
                "fontStyle": "bold"
              }
            },
            {
              "scope": "regex.tag.info",
              "settings": {
                "foreground": "#2866c4b9",
                "fontStyle": "bold"
              }
            },
            {
              "scope": "regex.infotext",
              "settings": {
                "foreground": "#264d88b9",
                "fontStyle": "bold"
              }
            },
            {
              "scope": "regex.tag.warn",
              "settings": {
                "foreground": "#e2850cb9",
                "fontStyle": "bold"
              }
            },
            {
              "scope": "regex.warntext",
              "settings": {
                "foreground": "#9c651cb9",
                "fontStyle": "bold"
              }
            },
            {
              "scope": "regex.tag.error",
              "settings": {
                "foreground": "#db1515b9",
                "fontStyle": "bold"
              }
            },
            {
              "scope": "regex.errortext",
              "settings": {
                "foreground": "#a81f1fb9",
                "fontStyle": "bold"
              }
            },
            {
              "scope": "regex.specialescape",
              "settings": {
                "foreground": "#acdb00b9",
                "fontStyle": "bold"
              }
            },
            {
              "scope": "regex.escaped",
              "settings": {
                "foreground": "#8100ccab",
                "fontStyle": "bold"
              }
            },
            {
              "scope": "regex.text",
              "settings": {
                "foreground": "#646c77",
                "fontStyle": "bold"
              }
            },
            {
              "scope": "source.regex",
              "settings": {
                "foreground": "#646c77",
                "fontStyle": "bold"
              }
            },
            {
              "scope": "regex.error",
              "settings": {
                "foreground": "#d10000ec",
                "fontStyle": "strikethrough"
              }
            },
            {
              "scope": "regex.group",
              "settings": {
                "foreground": "#006b20ee",
                "fontStyle": "bold"
              }
            }
          ]
        }
      }
    },
    "commands": [
      {
        "command": "autoRegex.openRegexFile",
        "icon": "$(regex)",
        "title": "Open Replace Regex"
      },
      {
        "command": "autoRegex.applyRegexesToAllFiles",
        "title": "apply regexes to all files"
      }
    ],
    "configuration": [
      {
        "properties": {
          "auto-regex.show regex errors as popup": {
            "default": 0,
            "description": "show regex errors as a popup",
            "type": "boolean"
          }
        },
        "title": ""
      }
    ],
    "grammars": [
      {
        "injectTo": [
          "source.js",
          "source.ts",
          "source.ahk2",
          "source.python",
          "source.gdscript",
          "source.regex"
        ],
        "path": "./syntaxes/jsregex.json",
        "scopeName": "source.regex"
      },
      {
        "language": "regex",
        "path": "./syntaxes/jsregex.json",
        "scopeName": "source.regex"
      }
    ],
    "languages": [
      {
        "aliases": [
          "regex"
        ],
        "configuration": "./language-configuration.json",
        "extensions": [
          ".regex"
        ],
        "id": "regex"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "autoRegex.openRegexFile",
          "group": "navigation",
          "when": "inSettingsEditor || resourceScheme == 'vscode-userdata' || inSettingsJSONEditor"
        }
      ]
    }
  },
  "dependencies": {
    "@types/vscode": "^1.91.0",
    "@vscode/vsce": "^3.1.1"
  },
  "description": "",
  "devDependencies": {
    "@types/mocha": "^10.0.8",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.11.1",
    "js-yaml": "^4.1.0",
    "typescript": "^5.6.2"
  },
  "displayName": "auto regex",
  "engines": {
    "vscode": "^1.91.0"
  },
  "main": "./out/extension.js",
  "name": "auto-regex",
  "publisher": "rssaromeo",
  "scripts": {
    "compile": "tsc -p ./",
    "lint": "eslint src",
    "pretest": "npm run compile && npm run lint",
    "test": "vscode-test",
    "vscode:prepublish": "npm run compile",
    "watch": "tsc -watch -p ./"
  }
}
